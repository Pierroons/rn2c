<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rn2c_bg">

    <LinearLayout
        android:id="@+id/rn2c_lang_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="36dp"
        android:paddingStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/rn2c_flag_fr"
            android:layout_width="36dp"
            android:layout_height="24dp"
            android:src="@drawable/flag_fr"
            android:contentDescription="Français"
            android:layout_marginEnd="8dp"
            android:alpha="1.0" />

        <ImageView
            android:id="@+id/rn2c_flag_en"
            android:layout_width="36dp"
            android:layout_height="24dp"
            android:src="@drawable/flag_en"
            android:contentDescription="English"
            android:alpha="0.4" />

    </LinearLayout>

    <TextView
        android:id="@+id/rn2c_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/rn2c_green_dim"
        android:textSize="11sp"
        android:fontFamily="@font/black_ops_one"
        android:paddingTop="36dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/rn2c_logo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/rn2c_logo"
        android:contentDescription="Logo RN2C"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/rn2c_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/rn2c_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RN2C"
        android:textColor="@color/rn2c_green"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="@font/black_ops_one"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/rn2c_mode_group"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rn2c_logo" />

    <!-- Étape 0 : choix du mode -->
    <LinearLayout
        android:id="@+id/rn2c_mode_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rn2c_title">

        <Button
            android:id="@+id/rn2c_btn_salon"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/rn2c_join_room"
            android:textColor="@color/rn2c_green"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:fontFamily="@font/black_ops_one"
            app:strokeColor="@color/rn2c_green"
            app:strokeWidth="2dp"
            android:backgroundTint="@color/rn2c_bg"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/rn2c_btn_portail"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/rn2c_portal"
            android:textColor="@color/rn2c_green_dim"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:fontFamily="@font/black_ops_one"
            app:strokeColor="@color/rn2c_green_dim"
            app:strokeWidth="1dp"
            android:backgroundTint="@color/rn2c_bg"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

    <!-- Étape 1 : choix anonyme / identifié -->
    <LinearLayout
        android:id="@+id/rn2c_choice_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rn2c_title">

        <Button
            android:id="@+id/rn2c_btn_anonymous"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/rn2c_anonymous"
            android:textColor="@color/rn2c_green"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:fontFamily="@font/black_ops_one"
            app:strokeColor="@color/rn2c_green"
            app:strokeWidth="2dp"
            android:backgroundTint="@color/rn2c_bg"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/rn2c_voice_changer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rn2c_voice_changer"
            android:textColor="@color/rn2c_green_dim"
            android:textSize="13sp"
            android:fontFamily="@font/black_ops_one"
            android:buttonTint="@color/rn2c_green"
            android:layout_marginBottom="12dp"
            android:paddingStart="8dp" />

        <Button
            android:id="@+id/rn2c_btn_login"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/rn2c_login"
            android:textColor="@color/rn2c_green_dim"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:fontFamily="@font/black_ops_one"
            app:strokeColor="@color/rn2c_green_dim"
            app:strokeWidth="1dp"
            android:backgroundTint="@color/rn2c_bg"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/rn2c_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/rn2c_username_hint"
            android:textColor="@color/rn2c_green"
            android:textColorHint="@color/rn2c_green_dim"
            android:textSize="16sp"
            android:fontFamily="@font/black_ops_one"
            android:background="@color/rn2c_bg_panel"
            android:padding="12dp"
            android:inputType="text"
            android:singleLine="true"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/rn2c_keep_identity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rn2c_keep_identity"
            android:textColor="@color/rn2c_green_dim"
            android:textSize="13sp"
            android:fontFamily="@font/black_ops_one"
            android:buttonTint="@color/rn2c_green"
            android:checked="true"
            android:visibility="gone"
            android:paddingStart="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/rn2c_btn_validate"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/rn2c_validate"
            android:textColor="@color/rn2c_green"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:fontFamily="@font/black_ops_one"
            app:strokeColor="@color/rn2c_green"
            app:strokeWidth="2dp"
            android:backgroundTint="@color/rn2c_bg"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Étape 2 : connexion en cours -->
    <LinearLayout
        android:id="@+id/rn2c_connect_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rn2c_title">

        <ProgressBar
            android:id="@+id/rn2c_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="#b040ff" />

        <TextView
            android:id="@+id/rn2c_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/rn2c_initializing"
            android:textColor="@color/rn2c_green_dim"
            android:textSize="16sp"
            android:fontFamily="@font/black_ops_one" />

    </LinearLayout>

    <!-- Écran de mise à jour forcée -->
    <LinearLayout
        android:id="@+id/rn2c_update_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rn2c_title">

        <TextView
            android:id="@+id/rn2c_update_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rn2c_green"
            android:textSize="16sp"
            android:fontFamily="@font/black_ops_one"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/rn2c_update_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:progressTint="#b040ff"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/rn2c_update_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rn2c_green_dim"
            android:textSize="12sp"
            android:fontFamily="@font/black_ops_one"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/rn2c_update_install"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/rn2c_update_install"
            android:textColor="@color/rn2c_green"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:fontFamily="@font/black_ops_one"
            app:strokeColor="@color/rn2c_green"
            app:strokeWidth="2dp"
            android:backgroundTint="@color/rn2c_bg"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
