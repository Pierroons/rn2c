<resources>
    <style name="Theme.Mumla" parent="Base.Theme.Mumla">
        <item name="colorPrimary">@color/rn2c_green</item>
        <item name="colorOnPrimary">@color/rn2c_bg</item>
        <item name="colorPrimaryContainer">@color/rn2c_green_dark</item>
        <item name="colorOnPrimaryContainer">@color/rn2c_green</item>
        <item name="colorSecondary">@color/rn2c_green_dim</item>
        <item name="colorOnSecondary">@color/rn2c_green</item>
        <item name="colorSurface">@color/rn2c_bg</item>
        <item name="colorOnSurface">@color/rn2c_green_text</item>
        <item name="colorSurfaceVariant">@color/rn2c_bg_panel</item>
        <item name="colorOnSurfaceVariant">@color/rn2c_green_text</item>
        <item name="android:colorBackground">@color/rn2c_bg</item>
        <item name="android:textColor">@color/rn2c_green_text</item>
        <item name="android:textColorPrimary">@color/rn2c_green_text</item>
        <item name="android:textColorSecondary">@color/rn2c_green_dim</item>
        <item name="android:textColorPrimaryInverse">@color/rn2c_green</item>
        <item name="android:textColorSecondaryInverse">@color/rn2c_green_dim</item>
        <item name="pttPressed">@color/rn2c_green_dim</item>
        <item name="popupOverlay">@style/ThemeOverlay.Material3.Dark</item>
        <item name="alertDialogTheme">@style/TweakedAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/TweakedMaterialAlertDialog</item>
        <item name="dialogPreferenceStyle">@style/TweakedDialogPreference</item>
        <item name="cardStyle">@style/Theme.Mumla.Dark.CardView</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/rn2c_bg</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="TweakedAlertDialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorPrimary">@color/rn2c_green</item>
        <item name="android:background">@color/rn2c_bg</item>
    </style>
    <style name="TweakedMaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/rn2c_green</item>
        <item name="android:background">@color/rn2c_bg</item>
    </style>
    <style name="TweakedDialogPreference" parent="Preference.DialogPreference.Material" />

    <style name="Theme.Mumla.Dark.CardView" parent="CardView">
        <item name="cardBackgroundColor">@color/rn2c_bg_panel</item>
    </style>
</resources>
